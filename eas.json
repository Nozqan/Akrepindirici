{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "production": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "node": "22.x",
      "npm": "10.x",
      "env": {
        "EXPO_USE_EAS_BUILD": "true"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "node": "22.x",
      "npm": "10.x",
      "env": {
        "EXPO_USE_EAS_BUILD": "true"
      }
    },
    "development": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.x",
      "npm": "10.x",
      "env": {
        "EXPO_USE_EAS_BUILD": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
